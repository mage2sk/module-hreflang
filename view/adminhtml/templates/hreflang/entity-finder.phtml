<div class="hf-finder-wrap">
    <div style="margin-bottom:6px;"><strong><?= $escaper->escapeHtml(__('Find Entity ID')) ?>:</strong>
        <span style="color:#666;font-size:12px;"><?= $escaper->escapeHtml(__('Entity IDs in member rows are interpreted according to the group\'s Entity Type. Use the matching button below to look one up by name.')) ?></span>
    </div>
    <button type="button" class="action-default scalable hf-finder-btn" data-hf-find="product">
        <span><?= $escaper->escapeHtml(__('Browse Products...')) ?></span>
    </button>
    <button type="button" class="action-default scalable hf-finder-btn" data-hf-find="category">
        <span><?= $escaper->escapeHtml(__('Browse Categories...')) ?></span>
    </button>
    <button type="button" class="action-default scalable hf-finder-btn" data-hf-find="cms_page">
        <span><?= $escaper->escapeHtml(__('Browse CMS Pages...')) ?></span>
    </button>
    <span id="hf-finder-hint" style="color:#eb5202;font-size:12px;margin-left:8px;display:none;"></span>
</div>

<div class="hf-finder-modal" id="hf-finder-modal">
    <div class="hf-finder-box">
        <div class="hf-finder-head">
            <strong id="hf-finder-title"><?= $escaper->escapeHtml(__('Find Entity')) ?></strong>
            <button type="button" class="hf-finder-close" aria-label="Close">&times;</button>
        </div>
        <div class="hf-finder-tools">
            <input type="search" id="hf-finder-q" placeholder="<?= $escaper->escapeHtmlAttr(__('Search by name, SKU, identifier or numeric ID')) ?>" autocomplete="off"/>
            <button type="button" class="action-default scalable" id="hf-finder-search-btn"><span><?= $escaper->escapeHtml(__('Search')) ?></span></button>
        </div>
        <div class="hf-finder-body" id="hf-finder-body">
            <div class="hf-finder-empty"><?= $escaper->escapeHtml(__('Enter a search term above and press Search.')) ?></div>
        </div>
        <div class="hf-finder-foot">
            <?= $escaper->escapeHtml(__('Click a row to copy its ID to the clipboard. Paste it into the Entity ID field of your chosen member row.')) ?>
        </div>
    </div>
</div>

<script>
    (function () {
        'use strict';
        var modal  = document.getElementById('hf-finder-modal');
        var title  = document.getElementById('hf-finder-title');
        var input  = document.getElementById('hf-finder-q');
        var body   = document.getElementById('hf-finder-body');
        var searchBtn = document.getElementById('hf-finder-search-btn');
        var searchUrl = <?= /* @noEscape */ json_encode($searchUrl) ?>;
        var currentType = 'product';

        function open(type) {
            currentType = type;
            var label = type === 'category' ? 'Categories' : (type === 'cms_page' ? 'CMS Pages' : 'Products');
            title.textContent = 'Find Entity - ' + label;
            modal.classList.add('open');
            input.value = '';
            body.innerHTML = '<div class="hf-finder-empty">Enter a search term or press Search to list the first 50.</div>';
            setTimeout(function () { input.focus(); }, 100);
            doSearch();
        }
        function close() { modal.classList.remove('open'); }

        function doSearch() {
            body.innerHTML = '<div class="hf-finder-empty">Searching...</div>';
            var url = searchUrl
                + (searchUrl.indexOf('?') > -1 ? '&' : '?')
                + 'type=' + encodeURIComponent(currentType)
                + '&q=' + encodeURIComponent(input.value || '')
                + '&isAjax=1';
            fetch(url, { credentials: 'same-origin', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    var items = (data && data.items) || [];
                    if (items.length === 0) {
                        body.innerHTML = '<div class="hf-finder-empty">No matches.</div>';
                        return;
                    }
                    var rows = items.map(function (i) {
                        var idText = String(i.id);
                        var labelText = (i.label || '').replace(/[<>&]/g, function (m) { return { '<':'&lt;', '>':'&gt;', '&':'&amp;' }[m]; });
                        return '<tr data-id="' + idText + '">'
                            +    '<td style="width:80px;"><strong>' + idText + '</strong></td>'
                            +    '<td>' + labelText
                            +    ' <button type="button" class="hf-pick-btn" data-pick="' + idText + '">Copy ID</button>'
                            +    '</td>'
                            + '</tr>';
                    }).join('');
                    body.innerHTML = '<table><thead><tr><th>ID</th><th>Name</th></tr></thead><tbody>' + rows + '</tbody></table>';
                })
                .catch(function () {
                    body.innerHTML = '<div class="hf-finder-empty" style="color:#e22626;">Search failed. Check the browser console.</div>';
                });
        }

        function copyId(id) {
            var ok = false;
            if (navigator.clipboard && navigator.clipboard.writeText) {
                try { navigator.clipboard.writeText(String(id)); ok = true; } catch (e) {}
            }
            if (!ok) {
                var ta = document.createElement('textarea');
                ta.value = String(id);
                document.body.appendChild(ta);
                ta.select();
                try { document.execCommand('copy'); ok = true; } catch (e) {}
                document.body.removeChild(ta);
            }
            if (ok && typeof window.alert === 'function') {
                // Subtle feedback instead of alert: briefly highlight the row.
                var tr = body.querySelector('tr[data-id="' + id + '"]');
                if (tr) {
                    tr.style.background = '#fef3c7';
                    setTimeout(function () { tr.style.background = ''; }, 800);
                }
            }
        }

        var buttons = Array.prototype.slice.call(document.querySelectorAll('[data-hf-find]'));
        var hint = document.getElementById('hf-finder-hint');

        function findEntityTypeSelect() {
            // Magento UI components render a hidden input with the form field
            // name alongside the select. The input keeps the authoritative
            // value and fires a native change event when the select changes.
            return document.querySelector(
                'input[name="entity_type"], select[name="entity_type"]'
            );
        }

        function syncButtonsToType() {
            var el = findEntityTypeSelect();
            var type = el ? String(el.value || '') : '';
            buttons.forEach(function (btn) {
                var btnType = btn.getAttribute('data-hf-find');
                var match = type === '' || btnType === type;
                btn.disabled = !match;
                btn.style.opacity = match ? '1' : '0.4';
                btn.style.cursor = match ? 'pointer' : 'not-allowed';
            });
            if (hint) {
                if (type === '') {
                    hint.style.display = 'inline';
                    hint.textContent = 'Pick an Entity Type above to enable the matching browser.';
                } else {
                    hint.style.display = 'none';
                }
            }
        }

        buttons.forEach(function (btn) {
            btn.addEventListener('click', function () {
                if (btn.disabled) { return; }
                open(btn.getAttribute('data-hf-find'));
            });
        });

        // Watch for entity_type changes. The KO-driven select in the form may
        // hydrate asynchronously, so poll briefly and attach a listener once
        // found. Also rebind when the DOM mutates (form re-renders on save).
        var wired = false;
        function wire() {
            if (wired) return;
            var el = findEntityTypeSelect();
            if (!el) return;
            wired = true;
            el.addEventListener('change', syncButtonsToType);
            // Bubbled changes from inner selects (KO binds to a hidden input
            // but user-facing select emits change on the visible element too).
            document.addEventListener('change', function (e) {
                if (e.target && (e.target.name === 'entity_type' || (e.target.closest && e.target.closest('[data-index="entity_type"]')))) {
                    setTimeout(syncButtonsToType, 0);
                }
            }, true);
            syncButtonsToType();
        }
        wire();
        var pollTimer = setInterval(function () { wire(); if (wired) clearInterval(pollTimer); }, 300);
        setTimeout(function () { clearInterval(pollTimer); }, 10000);
        modal.querySelector('.hf-finder-close').addEventListener('click', close);
        modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
        searchBtn.addEventListener('click', doSearch);
        input.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); doSearch(); } });
        body.addEventListener('click', function (e) {
            var btn = e.target.closest('[data-pick]');
            if (btn) { e.preventDefault(); e.stopPropagation(); copyId(btn.getAttribute('data-pick')); return; }
            var tr = e.target.closest('tr[data-id]');
            if (tr) copyId(tr.getAttribute('data-id'));
        });
    })();
</script>
