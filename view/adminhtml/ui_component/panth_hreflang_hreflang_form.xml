<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_hreflang_hreflang_form.panth_hreflang_hreflang_form_data_source</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="delete" class="Panth\Hreflang\Block\Adminhtml\GenericDeleteButton"/>
            <button name="save_and_continue" class="Panth\Hreflang\Block\Adminhtml\GenericSaveAndContinueButton"/>
            <button name="save" class="Panth\Hreflang\Block\Adminhtml\GenericSaveButton"/>
            <button name="back" class="Panth\Hreflang\Block\Adminhtml\GenericBackButton"/>
        </buttons>
        <namespace>panth_hreflang_hreflang_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>panth_hreflang_hreflang_form.panth_hreflang_hreflang_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="panth_hreflang_hreflang_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="panth_hreflang/hreflang/save"/>
        </settings>
        <dataProvider class="Panth\Hreflang\Ui\Component\Form\DataProvider\HreflangFormDataProvider" name="panth_hreflang_hreflang_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>group_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">General</label>
        </settings>
        <field name="group_id" formElement="input">
            <settings>
                <visible>false</visible>
                <dataType>text</dataType>
            </settings>
        </field>
        <field name="entity_type" formElement="select">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Entity Type</label>
                <dataScope>entity_type</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="product" xsi:type="array">
                                <item name="value" xsi:type="string">product</item>
                                <item name="label" xsi:type="string" translate="true">Product</item>
                            </option>
                            <option name="category" xsi:type="array">
                                <item name="value" xsi:type="string">category</item>
                                <item name="label" xsi:type="string" translate="true">Category</item>
                            </option>
                            <option name="cms_page" xsi:type="array">
                                <item name="value" xsi:type="string">cms_page</item>
                                <item name="label" xsi:type="string" translate="true">CMS Page</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="code" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Group Code</label>
                <dataScope>code</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="notes" formElement="textarea">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Notes</label>
                <dataScope>notes</dataScope>
            </settings>
        </field>
        <field name="is_active" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Active</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
    <fieldset name="members">
        <settings>
            <label translate="true">Members</label>
        </settings>
        <field name="members_note" formElement="input">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="notice" xsi:type="string" translate="true">Hreflang members are managed separately after saving the group.</item>
                    <item name="visible" xsi:type="boolean">true</item>
                    <item name="disabled" xsi:type="boolean">true</item>
                </item>
            </argument>
            <settings>
                <dataType>text</dataType>
                <label translate="true">Note</label>
                <dataScope>members_note</dataScope>
            </settings>
        </field>
    </fieldset>
</form>
