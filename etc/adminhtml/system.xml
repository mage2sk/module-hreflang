<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="panth_hreflang" translate="label" sortOrder="85" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>Hreflang</label>
            <tab>panth</tab>
            <resource>Panth_Hreflang::config</resource>

            <group id="hreflang" translate="label" sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Hreflang</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Outputs hreflang link tags for multi-language/multi-region stores to help search engines serve the correct locale.</comment>
                </field>
                <field id="emit_x_default" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Emit x-default</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Includes an x-default hreflang tag pointing to the default store, used by search engines when no locale matches the user.</comment>
                </field>
                <field id="hreflang_scope" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Hreflang Scope</label>
                    <source_model>Panth\Hreflang\Model\Config\Source\HreflangScope</source_model>
                    <comment>Determines whether hreflang tags are resolved at website or global level.</comment>
                </field>
                <field id="cms_relation_method" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>CMS Page Relation Method</label>
                    <source_model>Panth\Hreflang\Model\Config\Source\CmsRelationMethod</source_model>
                    <comment>How CMS pages across stores are matched for hreflang: by ID, URL key, or identifier.</comment>
                </field>
                <field id="diagnostic" translate="label" type="text" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Configuration Diagnostic</label>
                    <frontend_model>Panth\Hreflang\Block\Adminhtml\System\Config\HreflangDiagnostic</frontend_model>
                    <comment>Automated hreflang configuration checks. Save configuration to refresh results.</comment>
                </field>
            </group>
        </section>
    </system>
</config>
