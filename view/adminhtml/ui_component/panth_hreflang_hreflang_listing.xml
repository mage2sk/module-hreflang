<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_hreflang_hreflang_listing.panth_hreflang_hreflang_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>panth_hreflang_hreflang_listing_columns</spinner>
        <deps>
            <dep>panth_hreflang_hreflang_listing.panth_hreflang_hreflang_listing_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="*/hreflang/edit"/>
                <class>primary</class>
                <label translate="true">Add New Hreflang Group</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="panth_hreflang_hreflang_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">group_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <dataProvider class="Panth\Hreflang\Ui\Component\Listing\DataProvider\HreflangDataProvider" name="panth_hreflang_hreflang_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>group_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Are you sure you want to delete the selected groups?</message>
                        <title translate="true">Delete items</title>
                    </confirm>
                    <url path="panth_hreflang/hreflang/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Delete</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="panth_hreflang_hreflang_listing_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>group_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="group_id">
            <settings>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="code">
            <settings>
                <label translate="true">Group Code</label>
                <filter>text</filter>
            </settings>
        </column>
        <column name="entity_type">
            <settings>
                <label translate="true">Entity Type</label>
                <filter>text</filter>
            </settings>
        </column>
        <column name="member_count">
            <settings>
                <label translate="true">Members</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <label translate="true">Active</label>
                <filter>select</filter>
                <dataType>select</dataType>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <label translate="true">Created</label>
                <filter>dateRange</filter>
                <dataType>date</dataType>
            </settings>
        </column>
        <actionsColumn name="actions" class="Panth\Hreflang\Ui\Component\Listing\Column\HreflangActions">
            <settings>
                <indexField>group_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
